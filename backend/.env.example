# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your MongoDB connection string (e.g., from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/restres?retryWrites=true&w=majority

# JWT Authentication
# Generate a strong secret key for production (e.g., using `require('crypto').randomBytes(64).toString('hex')`)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d

# Frontend Configuration
# URL of the frontend application (for CORS)
CLIENT_URL=http://localhost:5173
